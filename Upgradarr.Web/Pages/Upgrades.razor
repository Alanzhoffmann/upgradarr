@page "/upgrades"
@using Upgradarr.Contracts
@inject HttpClient Http

<PageTitle>Upgrades</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
    <h1>Upgrades</h1>
    <FluentSwitch @bind-Value="ShowPendingOnly" @bind-Value:after="LoadData">Show Pending Only</FluentSwitch>
</div>

@if (upgrades == null)
{
    <FluentProgressRing />
}
else
{
    <div style="overflow-x: auto; width: 100%;">
        <FluentDataGrid Items="@upgrades.AsQueryable()" Style="min-width: 600px; width: 100%;" GridTemplateColumns="1fr 1fr 1fr 1fr">
            <PropertyColumn Title="Title" Property="@(p => p.Title ?? "Unknown")" Sortable="true" />
            <PropertyColumn Title="Type" Property="@(p => p.ItemType)" Sortable="true" />
            <PropertyColumn Title="State" Property="@(p => p.SearchState)" Sortable="true" />
            <PropertyColumn Title="Queue Position" Property="@(p => p.QueuePosition)" Sortable="true" />
        </FluentDataGrid>
    </div>
}

@code {
    private List<UpgradeStateDto>? upgrades;
    private bool ShowPendingOnly = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var endpoint = ShowPendingOnly ? "api/upgrade/pending" : "api/upgrade";
        upgrades = await Http.GetFromJsonAsync<List<UpgradeStateDto>>(endpoint);
    }
}
